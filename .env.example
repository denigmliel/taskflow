# ============================================
# TASKFLOW — Environment Variables
# Salin file ini menjadi .env.local
# ============================================

# --- DATABASE (Supabase) ---
# Dapatkan dari: Supabase Dashboard → Settings → Database → Connection String
# Pilih "URI" → Transaction mode (port 6543) untuk DATABASE_URL
# Pilih "URI" → Session mode (port 5432) untuk DIRECT_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- NEXTAUTH ---
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-32-karakter"
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production (isi setelah deploy ke Vercel):
# NEXTAUTH_URL="https://your-app.vercel.app"

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TaskFlow"
